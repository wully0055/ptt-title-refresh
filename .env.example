# 複製此檔為 .env 並填入實際值：cp .env.example .env

# ===== 必填 =====

# 要監控的 PTT 看板頁面（通常是看板的 index.html 或搜尋結果頁）
PTT_URL=https://www.ptt.cc/bbs/Drama-Ticket/index.html

# 文章標題關鍵字（不分大小寫）
KEYWORD=五月天

# 寄件者 Gmail 帳號
SENDER_EMAIL=example@gmail.com

# 收件者 Email，多個以逗號分隔
RECEIVER_EMAILS=example@gmail.com,example2@gmail.com

# Google 應用程式密碼（不是 Gmail 登入密碼）
# 申請方式：https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=

# ===== 選填 =====

# 檢查間隔秒數，預設 900（15 分鐘）
#CHECK_INTERVAL_SECONDS=900

# 已通知文章的紀錄檔路徑，預設 seen_posts.json
#SEEN_POSTS_FILE=seen_posts.json
